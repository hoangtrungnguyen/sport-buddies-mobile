SUPABASE_URL=
SUPABASE_KEY=

# Supavisor session-mode pooler (IPv4-reachable; required for Alembic / prepared statements).
# Direct host db.<ref>.supabase.com is IPv6-only and won't work from IPv4-only networks.
DATABASE_URL=postgresql://<ref.com:5432/snb_dev

# App-runtime: transaction-mode pooler (port 6543) — use for short-lived queries.
# DATABASE_URL_TXN=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=s
VIETMAP_API_KEY=

# Map tile provider: 'google' (default) or 'vietmap'
MAP_PROVIDER=google
# Google Maps API key — leave empty in dev to use keyless endpoint
GOOGLE_MAP_API_KEY=