# Grava worktrees
.worktree/

# Dart / Flutter
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages
*.iml

# IDE
.idea/
.DS_Store

# Per-package pubspec.lock (app pubspec.lock IS checked in upstream;
# library packages' lockfiles are not — keep both excluded at root and
# allow per-package overrides via nested .gitignore when needed)
packages/*/pubspec.lock

# FVM — keep .fvm/fvm_config.json and .fvmrc tracked; ignore the
# locally-managed SDK symlink + cache.

.env
zai-run.sh
claude_code_zai_env.sh
.mcp.json
.claude/
.claude/settings.json

# FVM Version Cache
.fvm/