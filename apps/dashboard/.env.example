# Copy to .env and fill in real values before running.
# Never commit .env — it is listed in .gitignore.

SUPABASE_JWKS_URL=https://<db-ref>.supabase.co/auth/v1/.well-known/jwks.json

# JWT audience claim — Supabase tokens use "authenticated" by default.
SUPABASE_JWT_AUDIENCE=authenticated
# ---------------------------------------------------------------------------
# Docker-compose local dev — PostgreSQL service variables
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=snb_backend
POSTGRES_REF=<ref>

# Key use for client app 
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
API_BASE_URL=


# By authentication values
BYPASS_AUTH=true
BYPASS_AUTH=dev@snb.com
BYPASS_PASSWORD=