# Copy to .env and fill in real values before running.
# Never commit .env — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------

# Django secret key — generate a fresh value for production:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

# Dotted-path to the settings module that Django loads.
# Use spb_core.settings for local dev, spb_core.settings.prod for production.
DJANGO_SETTINGS_MODULE=spb_core.settings

# Set to False in production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs Django will serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database — PostgreSQL connection string
# ---------------------------------------------------------------------------
# Local dev (Docker / native Postgres):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snb_backend
#
# Hosted Supabase — use the Supavisor pooler. The direct host
# (db.<ref>.supabase.co:5432) is IPv6-only and will fail from IPv4-only
# networks. Get the pooler URL from:
#   Supabase Dashboard → Project Settings → Database → Connection Pooling
#
# Session mode (port 5432) — required for Alembic migrations and Django ORM
# with named cursors. Use this as the default DATABASE_URL:
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
#
# Transaction mode (port 6543) — PgBouncer pooler, better connection pooling
# for app runtime queries. Switch to this for production app runtime if you are
# not running migrations or using named cursors:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Supabase project credentials
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---------------------------------------------------------------------------
# Supabase JWT / JWKS (used by auth middleware for token verification)
# ---------------------------------------------------------------------------
# JWKS endpoint — usually https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# JWT audience claim — Supabase tokens use "authenticated" by default.
SUPABASE_JWT_AUDIENCE=authenticated

# ---------------------------------------------------------------------------
# Docker-compose local dev — PostgreSQL service variables
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=snb_backend

# ---------------------------------------------------------------------------
# Optional / future
# ---------------------------------------------------------------------------
# Redis URL for Django Channels (required when channels are enabled)
# REDIS_URL=redis://localhost:6379/0
