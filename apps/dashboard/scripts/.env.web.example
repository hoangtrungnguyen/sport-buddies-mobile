# Copy to scripts/.env.web (git-ignored) and fill in real values.
# Consumed by scripts/run_web.sh -> --dart-define at run time.

# Supabase project (local CLI default URL shown). Real auth needs a real key.
SUPABASE_URL=http://localhost:54321
# Current Supabase key scheme — the client (publishable) key. Legacy
# SUPABASE_ANON_KEY is still accepted as a fallback.
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY is server-side ONLY — never put it here; it must not ship
# in the web client.

# REST backend (Django) base URL — owner signup et al.
# Web RELEASE builds must use https:// (main.dart enforces this).
API_BASE_URL=http://localhost:8010

# Optional: pre-fill the login form during development.
# DEV_EMAIL=owner@example.com
# DEV_PASSWORD=

# Optional: auto-login as a dev account on boot (preview without typing creds).
# BYPASS_AUTH=true
# BYPASS_EMAIL=dev@snb.com
# BYPASS_PASSWORD=

# Optional run overrides (or pass inline: DEVICE=web-server ./scripts/run_web.sh)
# DEVICE=chrome
# PORT=8090
