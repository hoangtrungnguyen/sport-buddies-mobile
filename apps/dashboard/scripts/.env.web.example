# Copy to scripts/.env.web (git-ignored) and fill in real values.
# Consumed by scripts/run_web.sh -> --dart-define at run time.

# Supabase project (local CLI default URL shown). Real auth needs a real anon key.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=

# REST backend (Django) base URL — owner signup et al.
# Web RELEASE builds must use https:// (main.dart enforces this).
API_BASE_URL=http://localhost:8000

# Optional: pre-fill the login form during development.
# DEV_EMAIL=owner@example.com
# DEV_PASSWORD=

# Optional run overrides (or pass inline: DEVICE=web-server ./scripts/run_web.sh)
# DEVICE=chrome
# PORT=8090
