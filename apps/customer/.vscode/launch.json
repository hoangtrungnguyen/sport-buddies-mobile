    "version": "0.2.0",
    "configurations": [
        {
            "name": "customer (local mode)",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define=ENVIRONMENT=local"
            ]
        },
        {
            "name": "customer (dev mode)",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define=ENVIRONMENT=dev"
            ]
        },
        {
            "name": "customer (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "customer (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}