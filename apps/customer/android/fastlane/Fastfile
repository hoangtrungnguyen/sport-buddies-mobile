# Fastlane pipeline for the SportBuddies customer app (Android).
#
# Lanes:
#   fastlane android build       — flutter release APK (envied codegen must
#                                  already be done; see deploy-customer-app.sh)
#   fastlane android distribute  — build + upload to Firebase App Distribution
#
# Required env for :distribute
#   FIREBASE_APP_ID                   1:<num>:android:<hash>  (Firebase console
#                                     or `firebase apps:list`)
#   FIREBASE_SERVICE_CREDENTIALS_FILE path to a service-account JSON with the
#                                     "Firebase App Distribution Admin" role
#                                     (GOOGLE_APPLICATION_CREDENTIALS also works)
# Optional:
#   ENVIRONMENT             dev|prod envied flavor      (default: dev)
#   FIREBASE_TESTER_GROUPS  comma-separated group aliases
#   FIREBASE_TESTERS        comma-separated tester emails
#   RELEASE_NOTES           defaults to the last git commit (hash + subject)

default_platform(:android)

# Flutter app root (apps/customer). Anchored on the fastlane folder location
# (android/fastlane) because Dir.pwd varies with how fastlane is launched and
# __dir__ is nil in an eval'd Fastfile.
# NOTE: this single Fastfile drives BOTH platforms — run iOS lanes from the
# android dir too: `cd android && bundle exec fastlane ios distribute`.
def app_root
  File.expand_path("../..", FastlaneCore::FastlaneFolder.path)
end

# Firebase credentials are OPTIONAL — when unset the plugin falls back to
# gcloud ADC and then the cached Firebase CLI login (`firebase login`).
# A service-account file is only required on CI machines.
def firebase_creds
  creds = ENV["FIREBASE_SERVICE_CREDENTIALS_FILE"].to_s
  creds = ENV["GOOGLE_APPLICATION_CREDENTIALS"].to_s if creds.empty?
  if creds.empty?
    UI.important("No service credentials file — using gcloud ADC / cached Firebase CLI login.")
    nil
  elsif !File.exist?(creds)
    UI.user_error!("Credentials file not found: #{creds}")
  else
    creds
  end
end

def default_release_notes
  notes = ENV["RELEASE_NOTES"].to_s
  return notes unless notes.empty?
  Dir.chdir(app_root) do
    sh("git", "log", "-1", "--pretty=%h %s", log: false).strip
  end
rescue StandardError
  "Manual build"
end

def require_environment!
  environment = ENV.fetch("ENVIRONMENT", "dev")
  # Only dev and prod go through this pipeline — local is for `flutter run`.
  unless %w[dev prod].include?(environment)
    UI.user_error!("ENVIRONMENT must be dev or prod (got '#{environment}')")
  end
  environment
end

platform :android do
  desc "Build the Flutter release APK"
  lane :build do
    environment = require_environment!
    UI.message("Building APK (ENVIRONMENT=#{environment})...")
    Dir.chdir(app_root) do
      sh("flutter", "build", "apk", "--release",
         "--dart-define=ENVIRONMENT=#{environment}")
    end
  end

  desc "Build and upload to Firebase App Distribution"
  lane :distribute do
    app_id = ENV["FIREBASE_APP_ID"].to_s
    UI.user_error!("FIREBASE_APP_ID not set") if app_id.empty?
    creds = firebase_creds

    build

    apk = File.join(app_root, "build/app/outputs/flutter-apk/app-release.apk")
    UI.user_error!("APK not found at #{apk}") unless File.exist?(apk)

    firebase_app_distribution(
      app: app_id,
      android_artifact_type: "APK",
      android_artifact_path: apk,
      service_credentials_file: creds,
      groups: ENV["FIREBASE_TESTER_GROUPS"],
      testers: ENV["FIREBASE_TESTERS"],
      release_notes: default_release_notes,
    )

    UI.success("Uploaded #{File.basename(apk)} to Firebase App Distribution")
  end
end

platform :ios do
  desc "Build the Flutter release IPA (release-testing/ad-hoc export)"
  lane :build do
    environment = require_environment!

    # Generated by deploy-customer-app.sh from APPLE_TEAM_ID; required because
    # `flutter build ipa` exports the archive with these options.
    export_plist = File.join(app_root, "ios/ExportOptionsAdHoc.plist")
    unless File.exist?(export_plist)
      UI.user_error!(
        "Missing ios/ExportOptionsAdHoc.plist — run via deploy-customer-app.sh " \
        "(generates it from APPLE_TEAM_ID), or create it manually."
      )
    end

    UI.message("Building IPA (ENVIRONMENT=#{environment})...")
    Dir.chdir(app_root) do
      sh("flutter", "build", "ipa", "--release",
         "--dart-define=ENVIRONMENT=#{environment}",
         "--export-options-plist=ios/ExportOptionsAdHoc.plist")
    end
  end

  desc "Build and upload to Firebase App Distribution"
  lane :distribute do
    app_id = ENV["FIREBASE_IOS_APP_ID"].to_s
    UI.user_error!("FIREBASE_IOS_APP_ID not set") if app_id.empty?
    creds = firebase_creds

    build

    ipa = Dir[File.join(app_root, "build/ios/ipa/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("No IPA found under build/ios/ipa/") unless ipa

    firebase_app_distribution(
      app: app_id,
      ipa_path: ipa,
      service_credentials_file: creds,
      groups: ENV["FIREBASE_TESTER_GROUPS"],
      testers: ENV["FIREBASE_TESTERS"],
      release_notes: default_release_notes,
    )

    UI.success("Uploaded #{File.basename(ipa)} to Firebase App Distribution")
  end
end
