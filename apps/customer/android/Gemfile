source "https://rubygems.org"

gem "fastlane"
# representable (google-apis transitive dep) requires multi_json without
# declaring it — without this line fastlane crashes at boot on Ruby 3.3.
gem "multi_json"

plugins_path = File.join(File.dirname(__FILE__), 'fastlane', 'Pluginfile')
eval_gemfile(plugins_path) if File.exist?(plugins_path)
